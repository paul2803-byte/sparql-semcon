# --- required -----------------------------------------------------------------
# Data endpoint of the Semantic Container (oydeu/dc-base) instance.
CONTAINER_DATA_URL=http://localhost:3000/api/data

# --- mapping -------------------------------------------------------------------
# RML/R2RML mapping that turns the container's JSON into RDF.
RML_MAPPING_PATH=config/mapping.ttl

# --- store ---------------------------------------------------------------------
# Empty = fast in-memory store (recommended). Set a directory path to persist.
STORE_PATH=

# --- synchronization -----------------------------------------------------------
SYNC_ON_STARTUP=true
# Re-sync every N seconds; 0 disables the timer (use POST /refresh instead).
SYNC_INTERVAL_SECONDS=0
# Merge paginated container responses (?page=1,2,...) into one dataset.
CONTAINER_PAGINATION=false

# --- authentication towards the container (pick one, or none) -------------------
# 1) static header:
#CONTAINER_AUTH_HEADER=Bearer eyJ...
# 2) OAuth2 client-credentials (dc-base / Doorkeeper):
#CONTAINER_CLIENT_ID=
#CONTAINER_CLIENT_SECRET=
# Optional; defaults to <origin of CONTAINER_DATA_URL>/oauth/token
#CONTAINER_TOKEN_URL=

# --- limits & misc ---------------------------------------------------------------
HTTP_TIMEOUT_SECONDS=30
MAX_QUERY_BYTES=50000
QUERY_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
